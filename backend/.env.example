# Copy this file to .env and fill in your actual values

PORT=5000

# Google Maps Platform API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Gemini / Generative AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Cloud / BigQuery
BIGQUERY_TABLE_ID=your_project.your_dataset.your_table
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/gcp-service-account-key.json

# Vertex AI / GCP Region
VERTEX_LOCATION=us-central1

# Firebase Cloud Messaging (FCM)
FCM_SERVER_KEY=your_fcm_server_key_here

# (Optional) Google Cloud Function URL for remote optimization engine
CLOUD_FUNCTION_URL=https://your-region-your-project.cloudfunctions.net/processTravelData

# (Optional) Google Cloud Storage bucket for query logging
GCS_LOG_BUCKET_NAME=your_gcs_bucket_name

# (Optional) Firebase credentials file path (for Firestore)
FIREBASE_CREDENTIALS_PATH=path/to/your/firebase-service-account.json

# (Optional) FCM device token for targeted push notifications
FCM_DEVICE_TOKEN=your_fcm_device_token_here
